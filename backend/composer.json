{
    "name": "tarombo/digital-backend",
    "description": "Backend API untuk Tarombo Digital",
    "type": "project",
    "require": {
        "php": "^8.1",
        "slim/slim": "^4.0",
        "slim/psr7": "^1.0",
        "firebase/php-jwt": "^6.0",
        "vlucas/phpdotenv": "^5.0",
        "illuminate/database": "^10.0",
        "illuminate/pagination": "^10.0",
        "monolog/monolog": "^3.0",
        "php-di/php-di": "^7.0",
        "phpoffice/phpspreadsheet": "^5.8",
        "mpdf/mpdf": "^8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.7",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpcs",
        "analyse": "phpstan analyse src --level=8"
    },
    "config": {
        "platform": {
            "php": "8.2.12"
        }
    }
}
