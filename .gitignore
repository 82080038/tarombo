# === DEVELOPMENT MODE — minimal gitignore ===
# .env, test-results, database exports, dll di-commit untuk memudahkan development di komputer lain
# vendor/ dan node_modules/ tetap di-ignore karena bisa di-regenerate dengan composer install & npm install

# Regenerable dependencies
backend/vendor/
tests/node_modules/

# Regenerable test output
tests/playwright-report/
test-results/
tests/test-results/

# OS files only
.DS_Store
Thumbs.db

# Editor swap files
*.swp
*.swo
*~

# PHPUnit cache (regenerable)
backend/.phpunit.cache/

# Playwright cache (regenerable)
playwright/.cache/
